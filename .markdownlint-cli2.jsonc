// https://github.com/DavidAnson/markdownlint/blob/v0.39.0/README.md#configuration
// https://github.com/DavidAnson/markdownlint-cli2/blob/main/test/markdownlint-cli2-jsonc-example/.markdownlint-cli2.jsonc
{
  "config": {
    "MD013": false, // Line length
    "MD028": false, // Blank line inside blockquote
    "MD032": false, // Lists should be surrounded by blank lines
  },
}
